rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the requesting user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users — read allowed for any logged-in user; write restricted to owner
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId);
    }

    // Usernames — read for everyone (even guests); write for authenticated users
    match /usernames/{username} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Friendships — owner can read/write any subcollection document
    match /friendships/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Teams — read for everyone (including guests); create for authenticated users;
    // update if user is appending their own UID using arrayUnion
    match /teams/{teamId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.resource.data.members.hasAll(resource.data.members) &&
        request.resource.data.members.removeAll(resource.data.members).hasOnly([request.auth.uid])
      );
    }

    // Solves — read for everyone; write for authenticated users
    match /solves/{solveId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
